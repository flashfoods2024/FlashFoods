<%- include("../partials/header", { pageTitle, flashSubtext: "If you don't see the password reset email within a minute, please check your Spam folder." }) %>

<div class="card">
  <h2>Forgot Password</h2>
  <form method="post" action="/forgot-password" class="form">
    <label>
      <span>Email</span>
      <input name="email" type="email" required />
    </label>
    <button class="btn" type="submit">Send Reset Link</button>
  </form>
  <p class="muted" style="margin-top:14px;"><a href="/login">Back to login</a></p>
</div>

<%- include("../partials/footer") %>
