<%- include("../partials/header", { pageTitle }) %>

<section class="hero hero--compact">
  <h1>Your cart</h1>
  <% if (shop) { %>
    <p class="muted">From <a href="/shops/<%= shop.slug %>"><%= shop.name %></a></p>
  <% } %>
</section>

<% if (!lines.length) { %>
  <div class="card">
    <p>Your cart is empty.</p>
    <a class="btn" href="/shops">Browse canteens</a>
  </div>
<% } else { %>
  <div class="card">
    <table class="table">
      <thead>
        <tr>
          <th>Item</th>
          <th>Price</th>
          <th>Qty</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% lines.forEach((line) => { %>
          <tr>
            <td>
              <%= line.name %>
              <% if (!line.available) { %>
                <span class="tag tag--warn">Unavailable</span>
              <% } %>
            </td>
            <td>₹<%= line.price.toFixed(2) %></td>
            <td>
              <form method="post" action="/cart/line" class="inline-form">
                <input type="hidden" name="menuItemId" value="<%= line.menuItemId %>" />
                <input class="input--qty" name="quantity" type="number" min="0" max="99" value="<%= line.quantity %>" />
                <button class="btn btn--ghost btn--small" type="submit">Update</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <p class="cart-total">
      <strong>Subtotal:</strong> ₹<%= subtotal.toFixed(2) %>
    </p>

    <div class="pickup-time-section">
      <label for="pickupTime">
        <strong>Pickup Time</strong>
      </label>

      <select id="pickupTime" class="input">
        <option value="">Select pickup time</option>
      </select>

      <p class="muted small">
        Choose when you plan to collect your order.
      </p>
    </div>

    <div class="row row--split">
      <form method="post" action="/cart/clear" onsubmit="return confirm('Clear cart?');">
        <button class="btn btn--ghost" type="submit">Clear cart</button>
      </form>

      <% if (!shop.paymentConfigured) { %>
        <button class="btn" type="button" disabled title="This shop has not configured payments yet">
          Checkout unavailable
        </button>
      <% } else if (shop.paymentProvider === "razorpay") { %>
        <button class="btn" id="pay-button">
          Pay with Razorpay
        </button>
      <% } else { %>
  <button class="btn" id="pay-button">
    Proceed to <%= shop.paymentProvider.charAt(0).toUpperCase() + shop.paymentProvider.slice(1) %>
  </button>
<% } %>
    </div>

    <% if (!shop.paymentConfigured) { %>
      <p class="muted small tag tag--warn">
        This canteen has not set up payments yet. Please check back later.
      </p>
    <% } else if (shop.paymentProvider === "razorpay") { %>
      <p class="muted small">
        You will get a pickup code after the canteen marks your order ready.
      </p>
    <% } %>
  </div>
<% } %>

<% if (shop && shop.paymentConfigured) { %>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
  const pickupSelect = document.getElementById("pickupTime");
  const paymentProvider = "<%= shop.paymentProvider %>";
  const publicKey = "<%= shop.paymentSettings?.apiKey || locals.env?.RAZORPAY_KEY_ID || '' %>";

  if (pickupSelect) {
    (function generatePickupTimes() {
      const now = new Date();

      for (let i = 5; i <= 120; i += 5) {
        const time = new Date(now.getTime() + i * 60000);
        const value = time.toISOString();
        const label = time.toLocaleTimeString([], {
          hour: "2-digit",
          minute: "2-digit",
        });

        pickupSelect.innerHTML += `
          <option value="${value}">
            ${label}
          </option>
        `;
      }
    })();
  }

  const payButton = document.getElementById("pay-button");

  if (payButton) {
    payButton.addEventListener("click", async () => {
      const pickupTime = pickupSelect?.value;

      if (!pickupTime) {
        alert("Please select a pickup time.");
        return;
      }

      const response = await fetch("/create-payment-order", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          amount: Number("<%= subtotal %>"),
          pickupTime,
        }),
      });

      const order = await response.json();

      if (order.error) {
        alert(order.error);
        return;
      }

      if (paymentProvider === "ccavenue") {
        // CCAvenue uses a browser POST with encrypted payload instead of an in-page widget.
        const form = document.createElement("form");
        form.method = "POST";
        form.action = order.gatewayUrl;
        form.style.display = "none";

        const encRequestInput = document.createElement("input");
        encRequestInput.type = "hidden";
        encRequestInput.name = "encRequest";
        encRequestInput.value = order.encRequest;

        const accessCodeInput = document.createElement("input");
        accessCodeInput.type = "hidden";
        accessCodeInput.name = "access_code";
        accessCodeInput.value = order.accessCode;

        form.appendChild(encRequestInput);
        form.appendChild(accessCodeInput);
        document.body.appendChild(form);
        form.submit();
        return;
      }

      const options = {
        key: order.publicKey || publicKey,
        amount: order.amount,
        currency: order.currency,
        name: "Flash Foods",
        description: "Order Payment",
        order_id: order.orderId || order.id,

        handler: async function (response) {
          const verifyResponse = await fetch("/verify-payment", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              ...response,
              pickupTime,
            }),
          });

          const data = await verifyResponse.json();

          if (data.success) {
            window.location.href = `/orders/${data.orderId}`;
          } else {
            alert(data.message || "Payment verification failed");
          }
        },
      };

      const rzp = new Razorpay(options);
      rzp.open();
    });
  }
</script>
<% } %>

<%- include("../partials/footer") %>
