<%- include("../partials/header", { pageTitle }) %>

<div class="breadcrumb">
  <a href="/orders">My orders</a>
  <span class="muted"> / </span>
  <span>...<%= String(order._id).slice(-6) %></span>
</div>

<% const studentLabel = order.status === "pending_payment" ? "Payment pending" : order.status === "paid" ? "Paid - waiting for canteen" : order.status === "accepted" ? "Order Accepted" : order.status === "ready_for_pickup" ? "Ready for pickup" : order.status === "completed" ? "Completed" : order.status; %>
<% const tagClass = order.status === "completed" ? "ok" : order.status === "ready_for_pickup" ? "pending" : order.status === "accepted" ? "pending" : order.status === "paid" ? "pending" : "muted"; %>
<% const displayLabel = order.status === "cancelled" ? "Order Cancelled" : studentLabel; %>
<% const displayTagClass = order.status === "cancelled" ? "warn" : tagClass; %>
<% const stepIndex = order.status === "completed" ? 5 : order.status === "ready_for_pickup" ? 4 : order.status === "accepted" ? 3 : order.pickupTime ? 2 : order.status === "pending_payment" ? 1 : 0; %>
<% const isAdjusted = !!(order.adjustedAt); %>
<% const removedItems = isAdjusted ? order.items.filter(function(i) { return i.status === "removed"; }) : []; %>
<% displayLabelAdj = (isAdjusted && order.status !== "completed" && order.status !== "cancelled") ? "Order Updated" : displayLabel; %>
<% displayTagClassAdj = (isAdjusted && order.status !== "completed" && order.status !== "cancelled") ? "warn" : displayTagClass; %>

<div class="card order-detail">
  <div class="order-detail__head">
    <div>
      <p class="eyebrow">Order ...<%= String(order._id).slice(-6) %></p>
      <h1>Order details</h1>
    </div>
    <span class="tag tag--<%= displayTagClassAdj %>"><%= displayLabelAdj %></span>
  </div>
  <p class="muted"><%= order.shop?.name || "Canteen" %> &middot; <%= new Date(order.createdAt).toLocaleString("en-IN", {
  timeZone: "Asia/Kolkata"
}) %></p>
  <p class="pickup-meta"><strong><%= (order.orderType || "dinein") === "parcel" ? "Parcel" : "Dine In" %></strong> &middot; <strong>Pickup time:</strong> <%= formatPickupTime(order.pickupTime) %></p>

  <% if (isAdjusted) { %>
    <div class="adjust-notice">
      <p><strong>Order Updated</strong></p>
      <% if (removedItems.length > 0) { %>
        <p class="muted">Unavailable: <%= removedItems.map(function(i) { return i.name; }).join(", ") %></p>
      <% } %>
      <p class="muted">Refund Amount: &#8377;<%= Number(order.refundAmount || 0).toFixed(2) %></p>
      <p class="muted">Updated Total: &#8377;<%= Number(order.updatedTotal || order.total).toFixed(2) %></p>
      <% if (order.adjustmentReason) { %>
        <p class="muted">Reason: <%= order.adjustmentReason %></p>
      <% } %>
    </div>
  <% } %>

  <% if (order.status !== "cancelled") { %>
    <ol class="progress-tracker" aria-label="Order progress">
      <% [
        ["Order Placed", 1],
        ["Pickup Scheduled", 2],
        ["Order Accepted", 3],
        ["Ready For Pickup", 4],
        ["Collected By Customer", 5],
      ].forEach(([label, index]) => { %>
        <li class="progress-tracker__step <%= stepIndex >= index ? "is-complete" : "" %> <%= stepIndex === index ? "is-current" : "" %>">
          <span class="progress-tracker__dot"><% if (stepIndex >= index) { %>&#10003;<% } else { %><%= index %><% } %></span>
          <span><%= label %></span>
        </li>
      <% }) %>
    </ol>
  <% } %>

  <% if (order.status === "paid") { %>
    <p class="muted">The canteen is preparing your order. When they mark it ready, your pickup code will appear here.</p>
  <% } else if (order.status === "accepted") { %>
    <p class="muted">Your order has been accepted by the canteen and is now being prepared.</p>
  <% } else if (order.status === "ready_for_pickup") { %>
    <div class="otp-box">
      <p class="otp-box__label">Pickup code</p>
      <p class="otp-box__code"><%= order.pickupOtp %></p>
      <p class="muted small">Show this code at the counter. The vendor enters it in <strong>Verify pickup</strong> when you collect.</p>
    </div>
  <% } else if (order.status === "completed") { %>
    <p class="muted">This order was picked up. Code used: <strong class="mono"><%= order.pickupOtp %></strong>.</p>
  <% } else if (order.status === "cancelled") { %>
    <p class="muted">Order Cancelled</p>
    <% if (order.refundStatus === "completed") { %>
      <p class="muted">Refund Initiated</p>
    <% } else if (order.refundStatus === "failed") { %>
      <p class="muted">Refund processing issue. Please contact support.</p>
    <% } %>
  <% } else if (order.status === "pending_payment") { %>
    <p class="muted">Complete payment when checkout supports it.</p>
  <% } %>

  <h2 class="h2">Items</h2>
  <ul class="plain-list">
    <% order.items.forEach((line) => { %>
      <li class="<%= line.status === 'removed' ? 'item-removed' : '' %>">
        <%= line.quantity %> x <%= line.name %>
        <% if (line.variantName) { %><span class="muted">(Variant: <%= line.variantName %>)</span><% } %>
        - &#8377;<%= (line.price * line.quantity).toFixed(2) %>
        <% if (line.status === "removed") { %><span class="muted small"> (unavailable)</span><% } %>
      </li>
    <% }) %>
  </ul>
  <% if (order.parcelCharge) { %>
    <p class="cart-total"><strong>Parcel Charge:</strong> &#8377;<%= Number(order.parcelCharge).toFixed(2) %></p>
  <% } %>
  <p class="cart-total"><strong>Total:</strong> &#8377;<%= (order.updatedTotal || order.total).toFixed(2) %></p>
</div>

<script>
  (function () {
    var orderId = "<%= order._id %>";
    var currentStatus = "<%= order.status %>";
    var wasAdjusted = <%= isAdjusted %>;

    var intervalId = setInterval(async function () {
      try {
        var res = await fetch("/api/orders/" + encodeURIComponent(orderId) + "/status", {
          headers: { Accept: "application/json" },
          credentials: "same-origin",
        });
        if (!res.ok) return;

        var data = await res.json();
        if ((data.status && data.status !== currentStatus) || (data.adjusted && !wasAdjusted)) {
          window.location.reload();
        }
      } catch (e) {
        // Keep polling; a temporary network hiccup should not break the page.
      }
    }, 5000);

    window.addEventListener("beforeunload", function () {
      clearInterval(intervalId);
    });
  })();
</script>

<%- include("../partials/footer") %>
