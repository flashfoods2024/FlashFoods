<%- include("../partials/header", { pageTitle }) %>

<style>
.pickup-banner {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  margin: -4px 0 10px 0;
  border-radius: 8px;
  font-weight: 700;
  font-size: 15px;
}
.pickup-banner--danger {
  background: #fee2e2;
  color: #991b1b;
  border-left: 4px solid #ef4444;
}
.pickup-banner--pending {
  background: #fef9c3;
  color: #854d0e;
  border-left: 4px solid #eab308;
}
.pickup-banner--ok,
.pickup-banner--muted {
  background: #f0fdf4;
  color: #166534;
  border-left: 4px solid #22c55e;
}
.pickup-banner__icon {
  font-size: 18px;
  flex-shrink: 0;
}
.pickup-banner__time {
  font-size: 17px;
  letter-spacing: 0.02em;
}
.pickup-banner__label {
  font-size: 10px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 2px 6px;
  border-radius: 4px;
  background: rgba(0,0,0,0.08);
}
.vendor-order-card__customer {
  font-size: 16px;
  font-weight: 700;
  color: #111827;
  margin: 2px 0 0 0;
}
.parcel-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.05em;
  padding: 3px 10px;
  border-radius: 4px;
  cursor: pointer;
  user-select: none;
  background: #f97316;
  color: #fff;
}
.parcel-badge:hover {
  opacity: 0.85;
}
.order-type-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 2px 8px;
  border-radius: 4px;
  cursor: pointer;
  transition: background 0.15s, color 0.15s;
  user-select: none;
}
.order-type-badge--dinein {
  background: #dbeafe;
  color: #1e40af;
}
.order-type-badge:hover {
  opacity: 0.8;
}
.verify-form--inline {
  display: flex;
  align-items: center;
  gap: 8px;
  width: 100%;
}
.verify-form--inline label {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 6px;
  margin: 0;
  font-size: 13px;
  font-weight: 600;
  color: #374151;
}
.verify-form--inline input {
  width: 100px;
  padding: 6px 8px;
  font-size: 16px;
  letter-spacing: 0.15em;
  text-align: center;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  font-family: monospace;
}
.verify-form--inline .btn {
  flex-shrink: 0;
  padding: 6px 16px;
  font-size: 14px;
}
.verify-error {
  color: #dc2626;
  font-size: 13px;
  margin: 4px 0 0 0;
}
.verify-success {
  color: #16a34a;
  font-size: 13px;
  margin: 4px 0 0 0;
}
.global-verify-bar {
  margin-bottom: 20px;
}
.global-verify-bar .card {
  padding: 16px 20px;
}
.global-verify-bar__head {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 10px;
}
.global-verify-bar__head h2 {
  margin: 0;
  font-size: 18px;
}
.global-verify-bar__count {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  padding: 2px 8px;
  border-radius: 10px;
  background: #dbeafe;
  color: #1e40af;
}
.global-verify-bar__form {
  display: flex;
  align-items: center;
  gap: 10px;
}
.global-verify-bar__form label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  font-weight: 600;
  color: #374151;
  flex-shrink: 0;
}
.global-verify-bar__form input {
  width: 120px;
  padding: 8px 10px;
  font-size: 18px;
  letter-spacing: 0.15em;
  text-align: center;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  font-family: monospace;
}
.global-verify-bar__form .btn {
  padding: 8px 20px;
  font-size: 15px;
}
.global-verify-bar__status {
  margin-top: 8px;
  font-size: 14px;
  font-weight: 600;
}
.global-verify-bar__status--success {
  color: #16a34a;
}
.global-verify-bar__status--error {
  color: #dc2626;
}
@media (max-width: 768px) {
  .pickup-banner { font-size: 14px; padding: 6px 10px; }
  .pickup-banner__time { font-size: 15px; }
}
</style>

<section class="hero hero--compact">
  <p class="eyebrow">Rush hour control</p>
  <h1>Pending orders</h1>
  <p class="muted">Accept new orders, mark them ready, and verify pickup codes when students arrive.</p>
</section>

<div class="global-verify-bar">
  <div class="card">
    <div class="global-verify-bar__head">
      <h2>Pickup Verification</h2>
      <span class="global-verify-bar__count" id="ready-count">0 ready</span>
    </div>
    <form id="global-verify-form" class="global-verify-bar__form">
      <label>
        <span>Pickup code</span>
        <input id="global-otp-input" name="otp" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="12" autocomplete="one-time-code" placeholder="000000" required />
      </label>
      <button class="btn" type="submit">Verify Pickup</button>
    </form>
    <div id="global-verify-status" class="global-verify-bar__status"></div>
  </div>
</div>

<div id="pending-orders-region">
<% if (!orders.length) { %>
  <div class="card empty-state">
    <p class="muted">No pending orders.</p>
  </div>
<% } else { %>
  <div class="vendor-order-grid">
    <% orders.forEach((order) => { %>
      <% const pickupUrgency = getPickupUrgency(order.pickupTime); %>
      <article class="card vendor-order-card">
        <a class="vendor-order-card__overlay" href="/vendor/orders/<%= order._id %>" aria-label="View order #<%= String(order._id).slice(-6).toUpperCase() %> details"></a>
        <div class="vendor-order-card__head">
          <div>
            <p class="eyebrow">Order</p>
            <h2>#<%= String(order._id).slice(-6).toUpperCase() %></h2>
            <% if (order.customerName) { %><p class="vendor-order-card__customer"><%= order.customerName %></p><% } %>
          </div>
          <div class="vendor-order-card__status">
            <span class="tag tag--<%= order.status === 'ready_for_pickup' ? 'ready' : 'pending' %>"><%= order.status === 'ready_for_pickup' ? 'Ready' : 'Preparing' %></span>
            <% if ((order.orderType || 'dinein') === 'parcel') { %>
              <span class="parcel-badge">&#x1F4E6; PARCEL</span>
            <% } else { %>
              <span class="order-type-badge order-type-badge--dinein">Dine In</span>
            <% } %>
            <span class="tag tag--<%= pickupUrgency %>">Pickup: <%= formatPickupTime(order.pickupTime) %></span>
          </div>
        </div>
        <% if (order.pickupTime) { %>
          <div class="pickup-banner pickup-banner--<%= pickupUrgency %>">
            <span class="pickup-banner__icon">&#9200;</span>
            <span class="pickup-banner__time"><%= formatPickupTime(order.pickupTime) %></span>
            <span class="pickup-banner__label"><%= pickupUrgency === 'danger' ? 'OVERDUE' : pickupUrgency === 'pending' ? 'SOON' : '' %></span>
          </div>
        <% } %>
        <ul class="vendor-order-card__items">
          <% order.items.filter(function(i) { return i.status !== "removed"; }).forEach((item) => { %>
            <li>
              <span><%= item.name %>
                <% if (item.variantName) { %>
                  <span class="muted small">(<%= item.variantName %>)</span>
                <% } %>
              </span>
              <strong><%= item.quantity %> x</strong>
            </li>
          <% }) %>
        </ul>
        <% if (order.parcelCharge) { %>
          <p class="cart-total"><strong>Parcel Charge:</strong> &#8377;<%= Number(order.parcelCharge).toFixed(2) %></p>
        <% } %>
        <p class="cart-total">
          <strong>Total:</strong> &#8377;<%= Number(order.total).toFixed(2) %>
        </p>
        <div class="vendor-order-card__actions">
          <% if (order.status === "paid") { %>
            <form method="post" action="/vendor/orders/<%= order._id %>/accept">
              <button class="btn btn--wide" type="submit">Accept Order</button>
            </form>
          <% } else if (order.status === "accepted") { %>
            <form method="post" action="/vendor/orders/<%= order._id %>/ready">
              <button class="btn btn--wide" type="submit">Mark ready</button>
            </form>
          <% } else if (order.status === "ready_for_pickup") { %>
            <form method="post" action="/vendor/verify" class="form verify-form verify-form--inline">
              <label>
                <span>Pickup code</span>
                <input name="otp" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="12" autocomplete="one-time-code" placeholder="000000" required />
              </label>
              <button class="btn" type="submit">Verify</button>
            </form>
          <% } %>
          <% if (["paid", "accepted"].includes(order.status)) { %>
            <a href="/vendor/orders/<%= order._id %>/adjust" class="btn btn--outline btn--wide">Adjust Order</a>
          <% } %>
          <% if (order.status === "paid") { %>
            <form
              method="post"
              action="/vendor/orders/<%= order._id %>/cancel"
              onsubmit="return confirm('Cancel this order and refund customer?');"
            >
              <button class="btn btn--danger btn--wide" type="submit">Cancel</button>
            </form>
          <% } %>
        </div>
      </article>
    <% }) %>
  </div>
<% } %>
</div>

<script>
  (function () {
    var region = document.getElementById("pending-orders-region");
    if (!region) return;

    var POLL_MS = 5000;
    var ENDPOINT = "/vendor/orders/pending.json";
    var lastSignature = null;
    var inFlight = false;
    var currentOrders = [];

    // Escape dynamic text before injecting into markup (item names are
    // vendor-supplied, so treat them as untrusted).
    function esc(value) {
      return String(value == null ? "" : value)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    // Build a single card matching the server-rendered markup exactly so all
    // CSS classes, the details overlay link, and the action forms behave the
    // same as the initial render.
    function cardHtml(order) {
      var itemsHtml = (order.items || [])
        .filter(function (item) { return item.status !== "removed"; })
        .map(function (item) {
          var variantHtml = item.variantName ? ' <span class="muted small">(' + esc(item.variantName) + ')</span>' : '';
          return (
            "<li><span>" +
            esc(item.name) +
            variantHtml +
            "</span><strong>" +
            esc(item.quantity) +
            " x</strong></li>"
          );
        })
        .join("");

      var id = esc(order.id);
      var shortId = esc(order.shortId);
      var customerName = order.customerName ? esc(order.customerName) : null;
      var orderType = order.orderType || "dinein";
      var st = order.status;
      var statusLabel = st === "ready_for_pickup" ? "Ready" : "Preparing";
      var statusClass = st === "ready_for_pickup" ? "ready" : "pending";
      var urgency = esc(order.pickupUrgency);
      var pickupLabel = esc(order.pickupTimeLabel);
      var total = Number(order.total).toFixed(2);
      var parcelCharge = Number(order.parcelCharge) || 0;

      var actionHtml;
      if (st === "paid") {
        actionHtml =
          '<form method="post" action="/vendor/orders/' +
          id +
          '/accept"><button class="btn btn--wide" type="submit">Accept Order</button></form>';
      } else if (st === "accepted") {
        actionHtml =
          '<form method="post" action="/vendor/orders/' +
          id +
          '/ready"><button class="btn btn--wide" type="submit">Mark ready</button></form>';
      } else if (st === "ready_for_pickup") {
        actionHtml =
          '<form method="post" action="/vendor/verify" class="form verify-form verify-form--inline">' +
          '<label><span>Pickup code</span>' +
          '<input name="otp" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="12" autocomplete="one-time-code" placeholder="000000" required />' +
          '</label>' +
          '<button class="btn" type="submit">Verify</button>' +
          '</form>';
      } else {
        actionHtml = "";
      }

      var adjustHtml = (st === "paid" || st === "accepted")
        ? '<a href="/vendor/orders/' + id + '/adjust" class="btn btn--outline btn--wide">Adjust Order</a>'
        : "";

      var cancelHtml = (st === "paid")
        ? '<form method="post" action="/vendor/orders/' + id + '/cancel" onsubmit="return confirm(\'Cancel this order and refund customer?\');"><button class="btn btn--danger btn--wide" type="submit">Cancel</button></form>'
        : "";

      var pickupBannerHtml = order.pickupTime
        ? '<div class="pickup-banner pickup-banner--' + urgency + '">' +
          '<span class="pickup-banner__icon">&#9200;</span>' +
          '<span class="pickup-banner__time">' + pickupLabel + '</span>' +
          '<span class="pickup-banner__label">' + (urgency === 'danger' ? 'OVERDUE' : urgency === 'pending' ? 'SOON' : '') + '</span>' +
          '</div>'
        : '';

      return (
        '<article class="card vendor-order-card">' +
        '<a class="vendor-order-card__overlay" href="/vendor/orders/' +
        id +
        '" aria-label="View order #' +
        shortId +
        ' details"></a>' +
        '<div class="vendor-order-card__head">' +
        '<div><p class="eyebrow">Order</p><h2>#' +
        shortId +
        "</h2>" +
        (customerName ? '<p class="vendor-order-card__customer">' + customerName + "</p>" : "") +
        "</div>" +
        '<div class="vendor-order-card__status">' +
        '<span class="tag tag--' + statusClass + '">' + statusLabel + '</span>' +
        (orderType === "parcel" ? '<span class="parcel-badge">\uD83D\uDCE6 PARCEL</span>' : '<span class="order-type-badge order-type-badge--dinein">Dine In</span>') +
        "</div></div>" +
        pickupBannerHtml +
        '<ul class="vendor-order-card__items">' +
        itemsHtml +
        "</ul>" +
        (parcelCharge > 0 ? '<p class="cart-total"><strong>Parcel Charge:</strong> &#8377;' + parcelCharge.toFixed(2) + '</p>' : '') +
        '<p class="cart-total"><strong>Total:</strong> &#8377;' +
        esc(total) +
        "</p>" +
        '<div class="vendor-order-card__actions">' +
        actionHtml +
        adjustHtml +
        cancelHtml +
        "</div></article>"
      );
    }

    function render(orders) {
      currentOrders = orders;
      var readyCount = orders.filter(function (o) { return o.status === "ready_for_pickup"; }).length;
      var countEl = document.getElementById("ready-count");
      if (countEl) countEl.textContent = readyCount + " ready";
      if (!orders.length) {
        region.innerHTML =
          '<div class="card empty-state"><p class="muted">No pending orders.</p></div>';
        return;
      }
      region.innerHTML =
        '<div class="vendor-order-grid">' +
        orders.map(cardHtml).join("") +
        "</div>";
    }

    // Handle OTP verification via AJAX so the vendor stays on the pending
    // orders page. Falls back to regular form POST if JS is unavailable.
    region.addEventListener("submit", function (e) {
      var form = e.target;
      if (!form.classList.contains("verify-form")) return;
      e.preventDefault();

      var otpInput = form.querySelector("[name=otp]");
      if (!otpInput) return;
      var otp = otpInput.value.replace(/\D/g, "").slice(0, 6);

      if (otp.length !== 6) {
        showVerifyError(form, "Enter the 6-digit pickup code.");
        return;
      }

      var btn = form.querySelector(".btn");
      if (btn) btn.disabled = true;

      fetch("/vendor/verify", {
        method: "POST",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        body: JSON.stringify({ otp: otp }),
        credentials: "same-origin",
      })
        .then(function (res) {
          if (!res.ok) {
            return res.json().then(function (data) {
              throw new Error(data.error || "Verification failed");
            });
          }
          return res.json();
        })
        .then(function () {
          poll();
        })
        .catch(function (err) {
          showVerifyError(form, err.message);
        })
        .finally(function () {
          if (btn) btn.disabled = false;
        });
    });

    function showVerifyError(form, msg) {
      var existing = form.querySelector(".verify-error");
      if (existing) existing.remove();
      var el = document.createElement("p");
      el.className = "verify-error";
      el.textContent = msg;
      form.appendChild(el);
    }

    // Global Pickup Verification Bar
    var globalForm = document.getElementById("global-verify-form");
    var globalInput = document.getElementById("global-otp-input");
    var globalStatus = document.getElementById("global-verify-status");

    if (globalForm && globalInput && globalStatus) {
      globalForm.addEventListener("submit", function (e) {
        e.preventDefault();
        globalStatus.textContent = "";
        globalStatus.className = "global-verify-bar__status";

        var otp = globalInput.value.replace(/\D/g, "").slice(0, 6);
        if (otp.length !== 6) {
          globalStatus.textContent = "Enter the 6-digit pickup code.";
          globalStatus.className = "global-verify-bar__status global-verify-bar__status--error";
          return;
        }

        var matches = currentOrders.filter(function (o) {
          return o.status === "ready_for_pickup" && o.pickupOtp === otp;
        });

        if (matches.length === 0) {
          globalStatus.textContent = "No Ready order matches this OTP.";
          globalStatus.className = "global-verify-bar__status global-verify-bar__status--error";
          return;
        }

        if (matches.length > 1) {
          globalStatus.textContent = "Multiple matching orders found.";
          globalStatus.className = "global-verify-bar__status global-verify-bar__status--error";
          return;
        }

        var btn = globalForm.querySelector(".btn");
        if (btn) btn.disabled = true;

        fetch("/vendor/verify", {
          method: "POST",
          headers: { "Content-Type": "application/json", Accept: "application/json" },
          body: JSON.stringify({ otp: otp }),
          credentials: "same-origin",
        })
          .then(function (res) {
            if (!res.ok) {
              return res.json().then(function (data) {
                throw new Error(data.error || "Verification failed");
              });
            }
            return res.json();
          })
          .then(function (data) {
            globalStatus.textContent = "Order #" + matches[0].shortId + " verified.";
            globalStatus.className = "global-verify-bar__status global-verify-bar__status--success";
            globalInput.value = "";
            poll();
            globalInput.focus();
          })
          .catch(function (err) {
            globalStatus.textContent = err.message;
            globalStatus.className = "global-verify-bar__status global-verify-bar__status--error";
            globalInput.focus();
          })
          .finally(function () {
            if (btn) btn.disabled = false;
          });
      });
    }

    // Order type toggle — one tap to switch Parcel / Dine In
    region.addEventListener("click", function (e) {
      var badge = e.target.closest(".order-type-badge");
      if (!badge) return;
      var card = badge.closest(".vendor-order-card");
      if (!card) return;
      var link = card.querySelector(".vendor-order-card__overlay");
      if (!link) return;
      var orderId = link.getAttribute("href").replace("/vendor/orders/", "");
      if (!orderId) return;

      badge.style.opacity = "0.5";
      fetch("/vendor/orders/" + encodeURIComponent(orderId) + "/toggle-parcel", {
        method: "POST",
        headers: { Accept: "application/json" },
        credentials: "same-origin",
      })
        .then(function (res) {
          if (!res.ok) throw new Error("Toggle failed");
          return res.json();
        })
        .then(function () {
          poll();
        })
        .catch(function () {
          badge.style.opacity = "1";
        });
    });

    function poll() {
      if (inFlight || document.hidden) return;
      inFlight = true;

      fetch(ENDPOINT, {
        headers: { Accept: "application/json" },
        credentials: "same-origin",
      })
        .then(function (res) {
          if (!res.ok) throw new Error("HTTP " + res.status);
          return res.json();
        })
        .then(function (data) {
          var orders = (data && data.orders) || [];
          var signature = JSON.stringify(orders);
          // Only touch the DOM when the data actually changed.
          if (signature !== lastSignature) {
            lastSignature = signature;
            render(orders);
          }
        })
        .catch(function (err) {
          // Network/server hiccup: log and keep polling, leave current list.
          console.error("Pending orders poll failed:", err);
        })
        .finally(function () {
          inFlight = false;
        });
    }

    // Refresh immediately when the tab becomes visible again.
    document.addEventListener("visibilitychange", function () {
      if (!document.hidden) poll();
    });

    setInterval(poll, POLL_MS);
  })();
</script>

<script>
  (function () {
    <% if (typeof vendorShop !== "undefined" && vendorShop && vendorShop._id) { %>
      var shopId = "<%= vendorShop._id %>";
      if (typeof NotificationManager !== "undefined") {
        window._notificationManager = new NotificationManager(shopId);
      }
    <% } %>
  })();
</script>

<%- include("../partials/footer") %>
