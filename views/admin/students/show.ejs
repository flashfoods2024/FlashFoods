<%- include("../../partials/header", { pageTitle }) %>
<%- include("../partials/layout-start", { activeSection }) %>

<section class="admin-page-head">
  <div>
    <p class="eyebrow">Student profile</p>
    <h1><%= student.name %></h1>
    <p class="muted"><%= student.email %></p>
  </div>
  <form method="post" action="/admin/students/<%= student._id %>/toggle" class="inline" onsubmit="return confirm('Toggle this student status?')">
    <button class="btn btn--ghost" type="submit"><%= student.isActive ? "Disable" : "Enable" %></button>
  </form>
</section>

<section class="admin-metrics">
  <article class="card admin-metric">
    <p class="muted small">Status</p>
    <h2 class="h2"><%= student.isActive === false ? "Disabled" : "Active" %></h2>
  </article>
  <article class="card admin-metric">
    <p class="muted small">Total Orders</p>
    <h2 class="h2"><%= stats.totalOrders %></h2>
  </article>
  <article class="card admin-metric">
    <p class="muted small">Last Order Date</p>
    <h2 class="h2"><%= stats.lastOrderDate ? new Date(stats.lastOrderDate).toLocaleDateString("en-IN", { timeZone: "Asia/Kolkata" }) : "None" %></h2>
  </article>
</section>

<div class="card admin-panel">
  <h2 class="h2">Student details</h2>
  <div class="admin-detail-grid">
    <div><span>Email</span><strong><%= student.email %></strong></div>
    <div><span>Created</span><strong><%= new Date(student.createdAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) %></strong></div>
    <div><span>Disabled at</span><strong><%= student.disabledAt ? new Date(student.disabledAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) : "Not disabled" %></strong></div>
  </div>
</div>

<div class="card admin-panel">
  <div class="row row--split">
    <h2 class="h2">Recent orders</h2>
    <a class="btn btn--outline btn--small" href="/admin/orders?q=<%= encodeURIComponent(student.name) %>">Search all orders</a>
  </div>
  <% if (!recentOrders.length) { %>
    <p class="muted">No orders yet.</p>
  <% } else { %>
    <div style="overflow-x: auto;">
      <table class="table admin-table">
        <thead>
          <tr>
            <th>Order</th>
            <th>Shop</th>
            <th>Status</th>
            <th>Total</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% recentOrders.forEach((order) => { %>
            <tr>
              <td><a class="admin-link" href="/admin/orders/<%= order._id %>">#<%= orderNumber(order) %></a></td>
              <td><%= order.shop?.name || "Deleted shop" %></td>
              <td><span class="tag tag--<%= order.status === "completed" ? "ok" : order.status === "cancelled" ? "danger" : order.status === "ready_for_pickup" ? "pending" : "muted" %>"><%= formatOrderStatus(order.status) %></span></td>
              <td><%= formatMoney(order.total) %></td>
              <td><%= new Date(order.createdAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include("../partials/layout-end") %>
<%- include("../../partials/footer") %>
