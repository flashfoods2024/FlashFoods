<%- include("../../partials/header", { pageTitle }) %>
<%- include("../partials/layout-start", { activeSection }) %>

<section class="admin-page-head">
  <div>
    <p class="eyebrow">Menu import</p>
    <h1>Processing menu...</h1>
    <p class="muted">Reading and extracting items from the uploaded file.</p>
  </div>
</section>

<div class="card" style="border-left: 4px solid var(--c-primary, #4361ee);">
  <div class="row row--split">
    <div>
      <p style="margin: 0; font-size: 0.9em; color: var(--c-muted, #888);">
        <%= vendor.name %> &middot; <%= vendor.email %> &middot; <%= shop.name %>
      </p>
    </div>
    <a class="btn btn--small btn--outline" href="/admin/vendors/<%= vendor._id %>/menu">&larr; Back to menu</a>
  </div>
</div>

<div class="card" style="text-align: center; padding: 48px 24px;">
  <div style="font-size: 48px; margin-bottom: 16px;">&#9203;</div>
  <h2 style="margin: 0 0 8px;">Processing your file</h2>
  <p class="muted" style="max-width: 400px; margin: 0 auto;">
    <strong><%= fileName %></strong> has been uploaded and is being analysed.
    Future OCR / AI parsers will extract menu items from this file and display
    them for review.
  </p>
  <hr style="margin: 24px auto; max-width: 200px; border: none; border-top: 1px solid var(--c-border, #ddd);" />
  <p class="muted" style="font-size: 0.85em;">
    Import ID: <code><%= importId %></code>
  </p>
  <a class="btn" href="/admin/vendors/<%= vendor._id %>/menu" style="margin-top: 16px;">
    Return to menu
  </a>
</div>

<%- include("../partials/layout-end") %>
<%- include("../../partials/footer") %>
